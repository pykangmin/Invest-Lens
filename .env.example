# Production / dev 공통 — Supabase Postgres pooler
# 형식: postgresql://<user>:<password>@<host>:5432/postgres?sslmode=require
DATABASE_URL=postgresql://readonly_user.project-ref:password@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres?sslmode=require

# (선택) 시장지수/환율 적재용 쓰기 권한 URL.
# 없으면 scripts/ingest-market-data.ts 는 DATABASE_URL 을 사용한다.
# MARKET_DATA_DATABASE_URL=postgresql://writer_user.project-ref:password@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres?sslmode=require

# (선택) dev 전용 — Figma REST API 토큰. scripts/figma-fetch.mjs 에서만 사용.
# Vercel production 환경에는 추가하지 말 것.
# FIGMA_TOKEN=figd_xxxxxxxxxxxxxxxx
# FIGMA_FILE_KEY=UJoPeW9SMzwDqX8B44eMrc
# FIGMA_ROOT_NODE=251:4045
